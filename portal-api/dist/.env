# ─── Variables de entorno ─────────────────────────────────────────
# Copiar este archivo a .env y completar los valores

# MongoDB
MONGODB_URI=mongodb://localhost:27017/portal_clientes
# En producción usar MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/portal_clientes

# JWT — usar un secreto largo y aleatorio en producción
JWT_SECRET=cambia_este_valor_por_uno_seguro_de_al_menos_32_caracteres

# Servidor
PORT=3000

# CORS — dominios permitidos en producción
CORS_ORIGIN=http://localhost:4200
