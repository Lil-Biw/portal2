{
  "compilerOptions": {
    "module": "CommonJS",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "incremental": true,
    "skipLibCheck": true,
    "strict": false,
    //"moduleResolution": "node",
    "esModuleInterop": true,
    //"baseUrl": "./",
    "ignoreDeprecations": "5.0"
  },
  "exclude": ["node_modules", "dist"]
}
